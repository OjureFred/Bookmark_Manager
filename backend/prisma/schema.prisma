generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Bookmark {
  id         String   @id @default(uuid())
  url        String
  title      String
  description String
  tags       Json     @default("[]")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([createdAt])
}